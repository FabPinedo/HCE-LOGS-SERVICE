# lg-pruebas-kafka — Audit Logger Service
# Generated by Jarvis Platform
# Copiar a .env y completar los valores marcados con ***

# ── Servidor ──────────────────────────────────────────────
PORT=10400
NODE_ENV=development

# ── Seguridad — API Key HTTP ───────────────────────────────
# Protege los endpoints GET /audit/* con una clave interna.
# Si está vacío el guard es permisivo (útil en desarrollo).
# En producción SIEMPRE establecer un valor largo y aleatorio.
# Uso: incluir header  x-api-key: <valor>  en cada request.
AUDIT_API_KEY=

# ── Kafka ─────────────────────────────────────────────────
# Broker(s) separados por coma — este servicio actúa como CONSUMER
KAFKA_BROKER=localhost:9092
# Topic del que consume eventos de auditoría
KAFKA_TOPIC=platform.logs

# ── SQL Server ────────────────────────────────────────────
DB_HOST=
DB_PORT=1433
DB_USER=
DB_PASS=
DB_NAME=audit_db
# Instancia nombrada de SQL Server (dejar vacío si usa puerto directo)
DB_INSTANCE=
